{
  "name": "so-git",
  "version": "1.0.0",
  "description": "一键为项目配置 commitlint + cz-git 的 CLI 工具",
  "main": "dist/index.mjs",
  "type": "module",
  "bin": {
    "so-git": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "test": "echo \"Error: no test specified\" && exit 1",
    "commit": "czg",
    "prepare": "simple-git-hooks"
  },
  "keywords": [
    "commitlint",
    "cz-git",
    "commitizen",
    "simple-git-hooks",
    "init-commitlint"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@inquirer/prompts": "^8.1.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "cz-git": "^1.12.0",
    "czg": "^1.12.0",
    "eslint": "^10.2.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit ${1}"
  },
  "commitizen": {
    "path": "node_modules/cz-git"
  }
}
